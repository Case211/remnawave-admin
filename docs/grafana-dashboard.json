{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Online users",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 25,
            "gradientMode": "opacity",
            "spanNulls": true,
            "showPoints": "never"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "panel_online_users{instance=~\"$instance\"}",
          "legendFormat": "online",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ]
    },
    {
      "id": 2,
      "title": "Users & nodes — current",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "panel_total_users{instance=~\"$instance\"}",
          "legendFormat": "Total users"
        },
        {
          "refId": "B",
          "expr": "panel_active_users{instance=~\"$instance\"}",
          "legendFormat": "Active users"
        },
        {
          "refId": "C",
          "expr": "panel_online_nodes{instance=~\"$instance\"}",
          "legendFormat": "Online nodes"
        },
        {
          "refId": "D",
          "expr": "panel_total_nodes{instance=~\"$instance\"}",
          "legendFormat": "Total nodes"
        },
        {
          "refId": "E",
          "expr": "panel_violations_open{instance=~\"$instance\"}",
          "legendFormat": "Open violations"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP RPS by status",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "showLegend": true, "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "stacking": { "mode": "normal", "group": "A" },
            "spanNulls": true,
            "showPoints": "never"
          },
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/^5../" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/^4../" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(panel_http_requests_total{instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 5,
            "spanNulls": true,
            "showPoints": "never"
          },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(panel_http_request_duration_seconds_bucket{instance=~\"$instance\"}[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(panel_http_request_duration_seconds_bucket{instance=~\"$instance\"}[$__rate_interval])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(panel_http_request_duration_seconds_bucket{instance=~\"$instance\"}[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 5,
      "title": "5xx error rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 16 },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "showLegend": false, "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 30,
            "gradientMode": "opacity",
            "showPoints": "never"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(panel_http_requests_total{instance=~\"$instance\",status=~\"5..\"}[$__rate_interval]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "id": 6,
      "title": "Requests in flight",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 16 },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (method) (panel_http_requests_in_progress{instance=~\"$instance\"})",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "DB pool usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 16 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "panel_db_pool_used{instance=~\"$instance\"}",
          "legendFormat": "used"
        },
        {
          "refId": "B",
          "expr": "panel_db_pool_size{instance=~\"$instance\"}",
          "legendFormat": "size"
        }
      ]
    },
    {
      "id": 8,
      "title": "Top endpoints by RPS",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (path) (rate(panel_http_requests_total{instance=~\"$instance\"}[$__rate_interval])))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Top endpoints by p95 latency",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, histogram_quantile(0.95, sum by (path, le) (rate(panel_http_request_duration_seconds_bucket{instance=~\"$instance\"}[$__rate_interval]))))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "Collector / violations / notifications (rate)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 30 },
      "description": "Counter-метрики событий. Появятся после первого .inc() в соответствующем коде.",
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "showLegend": true, "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": true,
            "showPoints": "never"
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(panel_collector_batches_received_total{instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "collector batches"
        },
        {
          "refId": "B",
          "expr": "sum by (severity) (rate(panel_violations_detected_total{instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "violations {{severity}}"
        },
        {
          "refId": "C",
          "expr": "sum by (channel) (rate(panel_notifications_sent_total{instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "notifications {{channel}}"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["remnawave", "panel"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "options": [],
        "refresh": 1,
        "skipUrlSync": false
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(panel_online_users, instance)",
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "hide": 0,
        "includeAll": true,
        "label": "Instance",
        "multi": true,
        "options": [],
        "refresh": 2,
        "regex": "",
